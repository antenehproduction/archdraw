{
  "permissions": {
    "allow": [
      "Read(*)",
      "Edit(index.html)",
      "Edit(CLAUDE.md)",
      "Edit(README.md)",
      "Edit(CLAUDE_CODE_GUIDE.md)",
      "Write(index.html)",
      "Write(CLAUDE.md)",
      "Write(README.md)",
      "Write(CLAUDE_CODE_GUIDE.md)",
      "Bash(git status)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git branch:*)",
      "Bash(git checkout:*)",
      "Bash(git pull:*)",
      "Bash(git fetch:*)"
    ],
    "deny": [
      "Bash(git reset --hard:*)",
      "Bash(git clean:*)",
      "Bash(git rebase:*)",
      "Bash(rm:*)",
      "Bash(rm -rf:*)",
      "Write(.github/**)",
    ]
  }
}
